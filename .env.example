# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# === OpenAI ===
# Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Realtime model — the assignment requires gpt-realtime-mini.
OPENAI_REALTIME_MODEL=gpt-realtime-mini
# Realtime voice (e.g. marin, alloy, cedar).
OPENAI_REALTIME_VOICE=marin

# === LiveKit Cloud (only needed to run the live voice worker) ===
# Create a free project at https://cloud.livekit.io and copy the keys.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Misc ===
# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
